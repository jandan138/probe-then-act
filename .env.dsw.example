# Copy to .env.dsw on the DSW machine and adjust paths for that workspace.
# Do not put tokens or passwords in this file.

PTA_REPO_URL=git@github.com:jandan138/probe-then-act.git
GENESIS_REPO_URL=git@github.com:jandan138/Genesis.git

PTA_CODE_ROOT=/cpfs/shared/simulation/zhuzihou/dev/probe-then-act
GENESIS_ROOT=/cpfs/shared/simulation/zhuzihou/dev/Genesis
GENESIS_VENV=/cpfs/shared/simulation/zhuzihou/dev/Genesis/.venv

PYTHON_BIN=python3
BOOTSTRAP_SKIP_INSTALL=0

DLC_RESULTS_ROOT=/cpfs/shared/simulation/zhuzihou/dev/probe-then-act/results/dlc
DLC_GPU_COUNT=1
DLC_IMAGE=dsw-registry-vpc.cn-beijing.cr.aliyuncs.com/pai-training-algorithm/pytorch:py311-cu126
DLC_DATA_SOURCES=

CHECKPOINT_BUNDLE_URL=
CHECKPOINT_BUNDLE_SHA256=

# Checkpoints are intentionally handled as release/storage artifacts:
# checkpoints are not stored in normal Git.
