\@writefile{lot}{\contentsline {table}{\numberline {I}{\ignorespaces Cross-material transfer efficiency (\%) across five evaluation splits. For M1 and M7, entries report mean $\pm $ seed standard deviation over 3 training seeds (10 deterministic episodes per seed). M7 leads on OOD elastoplastic by 14.7\,pp; per-seed dispersion on elastoplastic is $\sim 40$\,pp and is shown explicitly in \cref  {fig:seeds}. M8 is a single-seed diagnostic privileged-parameter baseline; no seed standard deviation is reported.}}{6}{table.caption.3}\protected@file@percent }
\newlabel{tab:main_results}{{I}{6}{Cross-material transfer efficiency (\%) across five evaluation splits. For M1 and M7, entries report mean $\pm $ seed standard deviation over 3 training seeds (10 deterministic episodes per seed). M7 leads on OOD elastoplastic by 14.7\,pp; per-seed dispersion on elastoplastic is $\sim 40$\,pp and is shown explicitly in \cref {fig:seeds}. M8 is a single-seed diagnostic privileged-parameter baseline; no seed standard deviation is reported}{table.caption.3}{}}
\newlabel{tab:main_results@cref}{{[table][1][]I}{[1][5][]6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Absolute transfer-efficiency landscape.} 3-method $\times $ 5-split heatmap of mean transfer efficiency (\%). M1 and M7 cells are 3-seed means (10 deterministic episodes per seed; per-seed dispersion in \cref  {fig:seeds}); M8 is scored from a single trained seed and serves as a diagnostic row. The OOD-elastoplastic column is outlined to flag the conditional finding: \textsc  {Probe-Then-Act}{} (M7) attains $60.7$\% transfer there versus $46.0$\% for the reactive baseline (M1) and $0$\% for the privileged-parameter baseline (M8). The complementary effect plot in \cref  {fig:hero} reports the same data as deltas relative to M1. M8 here is a sand-only-trained residual policy that additionally receives ground-truth $(E,\nu ,\rho ,\dots  )$; its elastoplastic collapse contains zero NaN events. Across all (method, split, seed) combinations reported in \cref  {tab:main_results,tab:ablation}, total NaN-rollout count was zero.}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:main}{{3}{6}{\textbf {Absolute transfer-efficiency landscape.} 3-method $\times $ 5-split heatmap of mean transfer efficiency (\%). M1 and M7 cells are 3-seed means (10 deterministic episodes per seed; per-seed dispersion in \cref {fig:seeds}); M8 is scored from a single trained seed and serves as a diagnostic row. The OOD-elastoplastic column is outlined to flag the conditional finding: \PTA {} (M7) attains $60.7$\% transfer there versus $46.0$\% for the reactive baseline (M1) and $0$\% for the privileged-parameter baseline (M8). The complementary effect plot in \cref {fig:hero} reports the same data as deltas relative to M1. M8 here is a sand-only-trained residual policy that additionally receives ground-truth $(E,\nu ,\rho ,\dots )$; its elastoplastic collapse contains zero NaN events. Across all (method, split, seed) combinations reported in \cref {tab:main_results,tab:ablation}, total NaN-rollout count was zero}{figure.caption.4}{}}
\newlabel{fig:main@cref}{{[figure][3][]3}{[1][5][]6}{}{}{}}
