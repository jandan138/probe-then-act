\@writefile{lot}{\contentsline {table}{\numberline {II}{\ignorespaces Ablation study on OOD Elastoplastic split. Removing the probe phase drops mean transfer by 27.6pp and falls below M1; removing the belief encoder drops 14.4pp from full \textsc  {Probe-Then-Act}{} and returns to roughly M1-level transfer. Success is the aggregate fraction over 30 episodes; equal transfer/spill standard deviations occur when per-seed spill is the complement of transfer.}}{6}{table.caption.5}\protected@file@percent }
\newlabel{tab:ablation}{{II}{6}{Ablation study on OOD Elastoplastic split. Removing the probe phase drops mean transfer by 27.6pp and falls below M1; removing the belief encoder drops 14.4pp from full \PTA {} and returns to roughly M1-level transfer. Success is the aggregate fraction over 30 episodes; equal transfer/spill standard deviations occur when per-seed spill is the complement of transfer}{table.caption.5}{}}
\newlabel{tab:ablation@cref}{{[table][2][]II}{[1][6][]6}{}{}{}}
