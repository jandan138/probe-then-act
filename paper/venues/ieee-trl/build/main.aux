\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Paired-seed slope chart, M1 vs.\ \textsc  {Probe-Then-Act}{}.} One panel per material split; each thin line connects matched-seed transfer efficiencies (M1 left, \textsc  {Probe-Then-Act}{} right) for the same training seed. Green slopes indicate \textsc  {Probe-Then-Act}{} $>$ M1 on that seed, red slopes indicate the reverse; the heavy black line connects 3-seed means. The OOD-elastoplastic panel (highlighted) is the only split where the seed mean rises and where \textsc  {Probe-Then-Act}{} exceeds M1 on 2 of 3 matched seed pairs (the third is closer). On the four other splits all per-seed slopes go down. Per-seed dispersion is largest on elastoplastic ($\sim 40$\,pp), so we report seed-level values directly in addition to means (\cref  {sec:results_stats}).}}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:seeds}{{5}{8}{\textbf {Paired-seed slope chart, M1 vs.\ \PTA {}.} One panel per material split; each thin line connects matched-seed transfer efficiencies (M1 left, \PTA {} right) for the same training seed. Green slopes indicate \PTA {} $>$ M1 on that seed, red slopes indicate the reverse; the heavy black line connects 3-seed means. The OOD-elastoplastic panel (highlighted) is the only split where the seed mean rises and where \PTA {} exceeds M1 on 2 of 3 matched seed pairs (the third is closer). On the four other splits all per-seed slopes go down. Per-seed dispersion is largest on elastoplastic ($\sim 40$\,pp), so we report seed-level values directly in addition to means (\cref {sec:results_stats})}{figure.caption.8}{}}
\newlabel{fig:seeds@cref}{{[figure][5][]5}{[1][7][]8}{}{}{}}
