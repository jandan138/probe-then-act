\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Ablation study on OOD elastoplastic.} Cleveland dot-plot matrix; each row is a method, each column a metric. Filled markers are 3-seed means; the horizontal whisker spans the per-seed minimum--maximum, and the small white dots show individual seed values (10 deterministic episodes per seed). Spill is plotted as ``Retained material'' ($100-\textrm  {spill}$) so that all three columns are higher-is-better. No-Probe falls below the reactive baseline on transfer; No-Belief is near the reactive baseline on transfer but remains below full \textsc  {Probe-Then-Act}{}.}}{7}{figure.caption.6}\protected@file@percent }
\newlabel{fig:ablation}{{4}{7}{\textbf {Ablation study on OOD elastoplastic.} Cleveland dot-plot matrix; each row is a method, each column a metric. Filled markers are 3-seed means; the horizontal whisker spans the per-seed minimum--maximum, and the small white dots show individual seed values (10 deterministic episodes per seed). Spill is plotted as ``Retained material'' ($100-\textrm {spill}$) so that all three columns are higher-is-better. No-Probe falls below the reactive baseline on transfer; No-Belief is near the reactive baseline on transfer but remains below full \PTA {}}{figure.caption.6}{}}
\newlabel{fig:ablation@cref}{{[figure][4][]4}{[1][6][]7}{}{}{}}
